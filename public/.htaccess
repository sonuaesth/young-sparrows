<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # Redirect www to non-www and HTTP to HTTPS
  RewriteCond %{HTTP_HOST} ^www\.youngsparrows\.com [NC,OR]
  RewriteCond %{HTTPS} off
  RewriteRule ^(.*)$ https://youngsparrows.com/$1 [L,R=301]

  RewriteRule ^index\.html$ - [L]
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteCond %{REQUEST_FILENAME} !-l
  RewriteRule . /index.html [L]
</IfModule>

<IfModule mod_headers.c>
  # HSTS Settings
  Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains"

  # X-Frame-Options Settings
  Header always set X-Frame-Options "SAMEORIGIN"

  # Referrer-Policy Settings
  Header always set Referrer-Policy "strict-origin-when-cross-origin"

  # X-Content-Type-Options Settings
  Header always set X-Content-Type-Options "nosniff"

  # CSP Settings
  Header always set Content-Security-Policy "default-src 'self' vrapcici.rs youngsparrows.com; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://maps.googleapis.com https://www.google.com https://www.gstatic.com https://www.google-analytics.com https://www.recaptcha.net https://www.emailjs.com https://www.googletagmanager.com https://connect.facebook.net https://log.cookieyes.com https://cdn-cookieyes.com https://mc.yandex.ru https://*.clarity.ms https://googleads.g.doubleclick.net; style-src 'self' 'unsafe-inline' https://cdn-cookieyes.com; img-src 'self' data: https://www.google-analytics.com https://www.google.com https://www.facebook.com https://cdn-cookieyes.com https://*.clarity.ms; connect-src 'self' https://api.emailjs.com https://www.googletagmanager.com https://log.cookieyes.com https://cdn-cookieyes.com https://www.google-analytics.com https://mc.yandex.ru https://pagead2.googlesyndication.com https://*.clarity.ms https://www.google.com; frame-src 'self' https://www.google.com https://maps.googleapis.com https://www.recaptcha.net https://www.googletagmanager.com https://mc.yandex.ru https://td.doubleclick.net https://*.clarity.ms;"
</IfModule>
